{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "wrtn-chat": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Wrtn Router",
      "options": {
        "baseURL": "http://127.0.0.1:8788/v1"
      },
      "models": {
        "claude-opus-4-8": {
          "name": "Claude Opus 4.8 (Wrtn Chat)",
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 (Wrtn Chat)",
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "claude-haiku-4-5-20251001": {
          "name": "Claude Haiku 4.5 (Wrtn Chat)",
          "limit": {
            "context": 200000,
            "output": 64000
          }
        },
        "gpt-5": {
          "name": "GPT-5 (Wrtn)",
          "limit": {
            "context": 400000,
            "output": 128000
          }
        },
        "gpt-4.1-mini": {
          "name": "GPT-4.1 Mini (Wrtn)",
          "limit": {
            "context": 1047576,
            "output": 32768
          }
        }
      }
    }
  }
}
